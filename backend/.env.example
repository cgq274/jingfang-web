# 支付配置示例（复制为 .env 并填写真实值，勿提交 .env）

# 站点基础 URL，用于支付回调（如 https://yourdomain.com）
PAYMENT_BASE_URL=https://yourdomain.com

# ----- 微信支付 V3 -----
WECHAT_PAY_ENABLED=1
# 微信应用 AppID（公众号/小程序/APP，按商户平台绑定的为准）
WECHAT_APP_ID=your_wechat_app_id
# 微信支付商户号（MCHID）
WECHAT_MCH_ID=your_wechat_mch_id
# APIv3 密钥（必须 32 位）
WECHAT_API_V3_KEY=your_32_chars_api_v3_key
WECHAT_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
# 微信支付平台证书公钥（建议放平台证书 PEM，而不是商户证书）
WECHAT_PUBLIC_KEY_PATH=./certs/wechat_platform_cert.pem
# 可选：平台证书序列号（若后续校验需要）
WECHAT_SERIAL_NO=
# 或直接写 PEM 内容：WECHAT_PRIVATE_KEY=、WECHAT_PUBLIC_KEY=

# ----- 支付宝 -----
ALIPAY_PAY_ENABLED=1
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY_PATH=./certs/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=./certs/alipay_public_key.pem
# 沙箱：ALIPAY_SANDBOX=1，正式：ALIPAY_SANDBOX=0
ALIPAY_SANDBOX=1
# 沙箱网关：https://openapi-sandbox.dl.alipaydev.com/gateway.do

# ----- 腾讯云 COS 存储 -----
# 不使用 COS 可留空；如要启用请填写完整
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=
