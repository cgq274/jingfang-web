# 支付配置示例（复制为 .env 并填写真实值，勿提交 .env）

# 站点基础 URL，用于支付回调（如 https://yourdomain.com）
PAYMENT_BASE_URL=https://yourdomain.com

# ----- 微信支付 V3 -----
WECHAT_PAY_ENABLED=0
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_PUBLIC_KEY_PATH=./certs/apiclient_cert.pem

# ----- 支付宝 -----
ALIPAY_PAY_ENABLED=0
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=./certs/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=./certs/alipay_public_key.pem
ALIPAY_SANDBOX=1
